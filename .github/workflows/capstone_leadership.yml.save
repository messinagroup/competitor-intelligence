name: Capstone Leadership Monitor

on:
  schedule:
    - cron: "0 */6 * * *"   # every 6 hours, on the hour
  workflow_dispatch:         # manual trigger from GitHub UI

jobs:
  monitor:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout repo
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      - name: Install dependencies
        run: pip install requests beautifulsoup4

      - name: Run monitor
        env:
          BPI_API_KEY: ${{ secrets.BPI_API_KEY }}
        run: python capstone_leadership_monitor.py

      # Persist state file between runs so diffs work correctly
      - name: Commit state file
        run: |
          git config user.name  "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"
          git add state/capstone_leadership_state.json
          git diff --staged --quiet || git commit -m "chore: update capstone leadership state [skip ci]"
          git push
